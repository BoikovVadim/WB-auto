NODE_ENV=development
BACKEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
# Глобальный рубильник «только чтение» для автоматики WB. true — ни один движок
# (вкл/выкл кластеров, DRR-регулятор, ставки) не пишет в кабинет WB; синки/расчёты идут.
# Нужен, чтобы поднять второй экземпляр (миграция в Oqqi) без двух писателей в один кабинет.
WB_AUTOMATION_READ_ONLY=false
WB_API_BASE_URL=https://seller-analytics-api.wildberries.ru
WB_API_TIMEOUT_MS=45000
WB_API_MIN_INTERVAL_MS=21000
WB_API_RETRY_ATTEMPTS=2
WB_API_RETRY_BASE_DELAY_MS=2000
WB_API_RETRY_MAX_DELAY_MS=8000
WB_DEFAULT_LOCALE=ru
WB_PROMOTION_API_BASE_URL=https://advert-api.wildberries.ru
WB_PROMOTION_API_TIMEOUT_MS=45000
WB_PROMOTION_API_MIN_INTERVAL_MS=300
WB_PROMOTION_BID_WRITE_MIN_INTERVAL_MS=700
WB_PROMOTION_BID_READ_MIN_INTERVAL_MS=220
WB_PROMOTION_MINUS_WRITE_MIN_INTERVAL_MS=200
WB_PROMOTION_MINUS_READ_MIN_INTERVAL_MS=200
WB_PROMOTION_DETAILS_MIN_INTERVAL_MS=2000
WB_PROMOTION_DETAILS_CHUNK_SIZE=25
WB_PROMOTION_STATS_MIN_INTERVAL_MS=6500
WB_PROMOTION_RETRY_ATTEMPTS=2
WB_PROMOTION_RETRY_BASE_DELAY_MS=15000
WB_PROMOTION_API_TOKEN=replace-me

# WB Statistics API (orders, sales). Uses the same token as WB_API_TOKEN by default.
# Rate limit: 1 req/min. Data retention: 90 days.
WB_STATISTICS_API_BASE_URL=https://statistics-api.wildberries.ru
WB_ORDERS_SYNC_ENABLED=true
# WB_ORDERS_SYNC_CRON=0 */30 * * * *
WB_PROMOTION_STATS_LOOKBACK_DAYS=30
WB_PROMOTION_SYNC_ENABLED=true
WB_PROMOTION_RAW_ARCHIVE_BATCH_SIZE=16
WB_PROMOTION_ENABLE_CMP_IN_FULL_SYNC=true
WB_PROMOTION_ENABLE_MONTHLY_FREQUENCY_IN_FULL_SYNC=true
WB_PROMOTION_ENABLE_JAM_IN_FULL_SYNC=false
WB_PROMOTION_JAM_SYNC_ENABLED=true
WB_PROMOTION_JAM_BACKFILL_LOOP_ENABLED=false
WB_CABINET_ENABLED=false
WB_CABINET_CMP_BASE_URL=https://cmp.wildberries.ru
WB_CABINET_HEADLESS=true
WB_CABINET_STORAGE_STATE_PATH=./backend/data/wb-cabinet-storage-state.json
WB_CABINET_EXECUTABLE_PATH=
WB_CABINET_REQUEST_TIMEOUT_MS=60000
WB_CABINET_PROBE_MAX_REQUESTS=60
WB_CABINET_ENABLE_IN_FULL_SYNC=true
WB_ARCHIVE_ROOT=./backend/data/search-queries
WB_API_TOKEN=replace-me
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/wb_automation
PGSSL=false
PGSCHEMA=public
VITE_API_BASE_URL=
# Базовый путь фронта при сборке. Пусто/"/" — корень домена (напр. sales.oqqi.io).
# Для legacy-подпути выставить "/wb/" (legendgames.space/wb). dev-режим всегда "/".
VITE_BASE_PATH=
